{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"outDir": "out",
		"lib": [
			"ES2020"
		],
		"types": [
			"node",
			"mocha"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"strictNullChecks": true,
		"noImplicitReturns": true,
		"noUnusedParameters": true,
	}
}
